# Neo4j for Mem0 graph memory (copy to .env and fill in)
# Local: neo4j://localhost:7687
# Aura:  neo4j+s://<your-instance>.databases.neo4j.io
OPENAI_API_KEY=your-openai-api-key

NEO4J_URL=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# Optional: override benchmark log output location.
# PERSONAMEM_BENCHMARK_LOGS_DIR=/absolute/path/to/benchmark_logs
